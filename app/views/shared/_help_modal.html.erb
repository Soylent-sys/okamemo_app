<button type="button" class="btn btn-help rounded-circle" data-bs-toggle="modal" data-bs-target="#helpModal">
  <h2 class="m-0"><i class="fas fa-question"></i></h2>
  <h6 class="m-0">ヘルプ</h6>
</button>
<div class="modal fade" id="helpModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel"><%= yield(:page_title) %>のヘルプ</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= render yield(:help_path) %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">閉じる</button>
      </div>
    </div>
  </div>
</div>
