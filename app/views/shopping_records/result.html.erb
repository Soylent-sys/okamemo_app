<% provide(:page_title, "お買い物履歴") %>
<% provide(:okame_info, "ここではお買い物履歴を見ることができるよ！\n買い物結果を見たいお買い物の青色の「リスト」ボタンを押してね。赤色の「ゴミ箱」のボタンを押すと履歴を削除することもできるよ。") %>
<%= render 'shared/navigation' %>
<% provide(:back_link_path, shopping_result_group_path) %>
<% provide(:back_link_text, "年月選択 にもどる") %>
<%= render 'shared/back_link' %>
<%= render 'shared/page_title' %>
<div class="col-xl-7 col-md-9 col-12 py-4 px-sm-2 px-3 my-5 mx-auto rounded-sr-index shopping-record-window-bg">
  <div class="col-sm-11 text-md-start text-center mx-auto mb-4">
    <h2><%= date_change_format_ja(params[:date]) %>の履歴一覧</h2>
  </div>
  <% @shopping_records.each do |shopping_record| %>
    <div class="col-sm-11 py-3 px-sm-3 px-2 mb-4 mx-auto rounded-2 shopping-record-bg">
      <div class="d-flex justify-content-between align-items-center">
        <h4 class="me-2 mb-0"><%= shopping_record.title %></h4>
        <div class="d-flex">
          <div class="me-sm-4 me-3">
            <%= link_to shopping_results_path(shopping_record.hashid) do %>
              <i class="h3 fas fa-rectangle-list m-0 show-icon"></i>
            <% end %>
          </div>
          <div>
            <%= button_to shopping_record_path(shopping_record.hashid), method: :delete, form: { data: { turbo_confirm: t('.confirm_to_delete'), turbo_confirm_title: "お買い物履歴の削除", turbo_confirm_submit_text: "削除する", turbo_confirm_button_class: 'btn btn-danger' } } do %>
              <i class="h3 fas fa-trash-can m-0 delete-icon"></i>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
  <% if @pagy.count > ShoppingRecordsController::RESULT_PAGENATION_SIZE %>
    <div class="d-flex justify-content-center">
      <%== pagy_bootstrap_nav(@pagy) %>
    </div>
  <% end %>
</div>
