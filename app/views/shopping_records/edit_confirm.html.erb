<% provide(:page_title, "お買い物モード") %>
<% provide(:okame_info, "お買い物結果を確認するよ！\nこの内容でよかったら「OK!」のボタンを押してね。") %>
<%= render 'shared/navigation' %>
<%= render 'shared/page_title' %>
<div class="col-xl-6 col-md-8 col-11 p-md-5 p-4 mb-5 mx-auto rounded-2 form-bg confirm-window-text">
  <h2 class="mb-md-4 mb-3">お買い物結果</h2>
  <div class="p-3 mb-4 rounded-2 confirm-window">
    <h4><i class="fas fa-book"></i>&ensp;お買い物タイトル</h4>
    <span class="h5 d-block ps-3"><%= @shopping_record.title %></span>
  </div>
  <div class="p-3 mb-4 rounded-2 confirm-window">
    <h4 class="py-2 mb-0"><i class="fas fa-bag-shopping"></i>&ensp;買ったアイテム</h4>
    <% if @shopping_record_form.hashids.present? %>
      <ul class="h5">
        <% bought_items(@shopping_record_form).each do |buy| %>
          <li class="ps-2 mb-2"><%= display_item_name_of_buy(buy) %></li>
        <% end %>
      </ul>
    <% else %>
      <h5 class="mt-1">&ensp;購入アイテムなし</h5>
    <% end %>
  </div>
  <div class="p-3 mb-4 rounded-2 confirm-window">
    <h4 class="py-2 mb-0"><i class="fas fa-apple-whole"></i>&ensp;買わなかったアイテム</h4>
    <% if no_bought_items(@shopping_record_form).present? %>
      <ul class="h5">
        <% no_bought_items(@shopping_record_form).each do |buy| %>
          <li class="ps-2 mb-2"><%= display_item_name_of_buy(buy) %></li>
        <% end %>
      </ul>
    <% else %>
      <h5 class="mt-1">&ensp;未購入アイテムなし</h5>
    <% end %>
  </div>
</div>
<div class="d-flex justify-content-center text-center mb-4">
  <div class="me-5">
    <%= form_with model: @shopping_record_form, url: shopping_record_path(@shopping_record_form.shopping_record_id), method: "put", local: true do |f| %>
      <%= f.hidden_field :shopping_record_id, value: @shopping_record_form.shopping_record_id %>
      <% if @shopping_record_form.hashids.present? %>
        <% @shopping_record_form.hashids.each do |hashid| %>
          <%= f.hidden_field :hashids, multiple: true, value: hashid %>
        <% end %>
      <% end %>
      <%= f.submit "OK!", class: "btn btn-lg btn-custom-send" %>
    <% end %>
  </div>
  <div>
    <%= form_with model: @shopping_record_form, url: shopping_progress_back_path, local: true do |f| %>
      <%= f.hidden_field :shopping_record_id, value: @shopping_record_form.shopping_record_id %>
      <% if @shopping_record_form.hashids.present? %>
        <% @shopping_record_form.hashids.each do |hashid| %>
          <%= f.hidden_field :hashids, multiple: true, value: hashid %>
        <% end %>
      <% end %>
      <%= f.submit "もどる", class: "btn btn-lg btn-secondary" %>
    <% end %>
  </div>
</div>
