<div class="container-fluid g-0 bg-white">
  <div class="d-flex">
    <%= render 'management/shared/sidebar' %>
    <div class="management-main p-4 bg-body-secondary">
      <h2 class="d-inline-block px-4 py-2 mb-3 rounded-2 bg-white">お買い物管理</h2>
      <div class="table-scroll">
        <table class="management-table rounded-2 bg-white">
          <thead>
            <tr>
              <th>ID</th>
              <th>User_ID</th>
              <th>Title</th>
              <th>Closed</th>
              <th>Created_at</th>
              <th>Updated_at</th>
              <th>詳細</th>
              <th>削除</th>
            </tr>
          </thead>
          <tbody>
            <% @shopping_records.each do |shopping_record| %>
              <tr>
                <td><%= shopping_record.id %></td>
                <td><%= shopping_record.user_id %></td>
                <td><%= shopping_record.title %></td>
                <td><%= shopping_record.closed? ? "完了" : "未完了" %></td>
                <td><%= shopping_record.created_at.to_fs(:date_time) %></td>
                <td><%= shopping_record.updated_at.to_fs(:date_time) %></td>
                <td class="text-center">
                  <%= link_to management_shopping_record_path(shopping_record.id) do %>
                    <i class="h5 fas fa-rectangle-list m-0 show-icon"></i>
                  <% end %>
                </td>
                <td class="text-center">
                  <%= button_to management_shopping_record_path(shopping_record.id), method: :delete, form: { data: { turbo_confirm: t('.confirm_to_delete'), turbo_confirm_title: "お買い物（ID: #{shopping_record.id}）の削除", turbo_confirm_submit_text: "削除する", turbo_confirm_button_class: 'btn btn-danger' } } do %>
                    <i class="h5 fas fa-trash-can m-0 delete-icon"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @pagy.pages > ConstantsHelper::SINGLE_PAGE %>
        <div class="mt-3 d-flex justify-content-center">
          <%== pagy_nav(@pagy, link_extra: 'class="border bg-white px-2 py-1 rounded link-secondary"') %>
        </div>
      <% end %>
    </div>
  </div>
</div>
