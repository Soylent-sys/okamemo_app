<% provide(:page_title, "アイテム登録") %>
<% provide(:okame_info, "新しいアイテムを登録したり、登録済みのアイテムを編集できるよ！\n新しく登録する時は「アイテム登録」ボタン、編集は登録したアイテムの「えんぴつ」ボタン、削除は「ゴミ箱」ボタンを押してね。") %>
<%= render 'shared/navigation' %>
<div class="d-flex justify-content-between">
  <div class="mt-1 mb-4 ms-sm-5 ms-3">
    <%= link_to :back, class: "h5 back-link text-decoration-none" do %>
      <i class="fas fa-circle-left link-icon"></i><span class="ms-1">もどる</span>
    <% end %>
  </div>
  <div>
    <%= link_to new_item_path, class: "btn btn-lg btn-custom-send me-sm-4 me-2" do %>
      <i class="fas fa-circle-plus me-2"></i>アイテム登録
    <% end %>
  </div>
</div>
<div class="container-fluid">
  <div class="row d-flex align-items-start px-1 pt-3 position-under-header category-item-head">
    <div class="col-xl-2 col-sm-3 col-5 category-window border-1rem-up"><h4 class="py-2 my-auto category-window-heading"><i class="fas fa-tree me-2"></i>カテゴリー</h4></div>
    <div class="col-xl-10 col-sm-9 col-7 item-window rounded-2"><h4 class="py-2 my-auto item-window-heading"><i class="fas fa-apple-whole me-2"></i>登録アイテム</h4></div>
  </div>
  <div class="row d-flex align-items-start px-1 mb-3">
    <div class="col-xl-2 col-sm-3 col-5 px-2 pb-2 category-window border-1rem-down">
      <div class="nav flex-column nav-pills category-bg" id="v-pills-tab" role="tablist" aria-orientation="vertical">
        <% @categories.each_with_index do |category, i| %>
          <% if current_user_create_items(category).length > 0 %>
            <button class="nav-link <%= "active" if i.zero? %>" id="v-pills-<%= i %>-tab" data-bs-toggle="pill" data-bs-target="#v-pills-<%= i %>" type="button" role="tab" aria-controls="v-pills-home" aria-selected="<%= i.zero? ? "true" : "false" %>"><%= category.name %></button>
          <% end %>
        <% end %>
      </div>
    </div>
    <div class="tab-content col-xl-10 col-sm-9 col-7 position-items" id="v-pills-tabContent">
      <% @categories.each_with_index do |category, i| %>
        <% if current_user_create_items(category).length > 0 %>
          <div class="tab-pane fade <%= "show active" if i.zero? %>" id="v-pills-<%= i %>" role="tabpanel" aria-labelledby="v-pills-<%= i %>-tab" tabindex="0">
            <div class="row mx-auto my-3">
              <% current_user_create_items(category).each do |item| %>
                <div class="h5 justify-content-between align-items-center col-md-4 d-flex px-3 py-3 mx-md-2 rounded-2 item-space item-bg">
                  <div class="item-name-space"><%= item.name %></div>
                  <div class="d-sm-flex d-block">
                    <div class="text-center me-sm-3 me-0 mb-sm-0 mb-3">
                      <%= link_to edit_item_path(item.id) do %>
                        <i class="h4 fas fa-pencil m-0 edit-icon"></i>
                      <% end %>
                    </div>
                    <div>
                      <%= button_to item_path(item.id), method: :delete, data: { turbo_confirm: "本当に削除しますか？" } do %>
                        <i class="h4 fas fa-trash-can m-0 delete-icon"></i>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
